{
  "entities": {
    "Review": {
      "title": "Review",
      "description": "A user-submitted product review",
      "type": "object",
      "properties": {
        "productId": {
          "type": "string",
          "description": "The ID of the product being reviewed"
        },
        "author": {
          "type": "string",
          "description": "Name of the reviewer"
        },
        "handle": {
          "type": "string",
          "description": "Social handle or formatted username"
        },
        "rate": {
          "type": "integer",
          "description": "Rating out of 5 stars"
        },
        "review": {
          "type": "string",
          "description": "Detailed review comment"
        },
        "date": {
          "type": "string",
          "description": "Date formatted as a legible string"
        },
        "avatar": {
          "type": "string",
          "description": "Avatar image URL"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of creation"
        }
      },
      "required": ["productId", "author", "handle", "rate", "review", "date", "avatar", "createdAt"]
    }
  },
  "firestore": {
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Collection of all product reviews submitted by users"
    }
  }
}
