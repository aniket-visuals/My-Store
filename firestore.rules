rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default-deny catch-all safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_-]+$'); 
    }
    
    function incoming() { 
      return request.resource.data; 
    }
    
    function existing() { 
      return resource.data; 
    }

    function isValidReview(data) {
      return data.keys().hasAll(['productId', 'author', 'handle', 'rate', 'review', 'date', 'avatar', 'createdAt'])
        && data.keys().size() == 8
        && data.productId is string && data.productId.size() >= 1 && data.productId.size() <= 64
        && data.author is string && data.author.size() >= 1 && data.author.size() <= 100
        && data.handle is string && data.handle.size() >= 1 && data.handle.size() <= 100 && data.handle.matches('^@[a-zA-Z0-9_-]+$')
        && data.rate is int && data.rate >= 1 && data.rate <= 5
        && data.review is string && data.review.size() >= 1 && data.review.size() <= 2000
        && data.date is string && data.date.size() >= 1 && data.date.size() <= 100
        && data.avatar is string && data.avatar.size() >= 1 && data.avatar.size() <= 1000
        && data.createdAt is timestamp;
    }

    match /reviews/{reviewId} {
      // Validate path ID
      allow get: if isValidId(reviewId);
      
      // List rules: allow anyone to list product reviews
      allow list: if true;
      
      // Create reviews publicly with full validation
      allow create: if isValidId(reviewId) 
        && isValidReview(incoming())
        && incoming().createdAt == request.time;
        
      // Deletions are allowed client-side
      allow delete: if isValidId(reviewId);
    }
  }
}
